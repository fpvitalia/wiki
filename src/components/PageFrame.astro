---
import MobileMenuToggle from 'virtual:starlight/components/MobileMenuToggle';

const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="page sl-flex">
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav class="sidebar print:hidden" aria-label={Astro.locals.t('sidebarNav.accessibleLabel')}>
        <MobileMenuToggle />
        <button
          type="button"
          class="sidebar-collapse-toggle"
          aria-label="Chiudi sidebar"
          aria-controls="starlight__sidebar"
          aria-expanded="true"
          data-sidebar-collapse-toggle
        >
          <span aria-hidden="true" data-sidebar-collapse-icon>‹</span>
        </button>
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
</div>

<script is:inline>
  (() => {
    const storageKey = 'fpvitalia-sidebar-collapsed';
    const root = document.documentElement;
    const toggle = document.querySelector('[data-sidebar-collapse-toggle]');
    const icon = document.querySelector('[data-sidebar-collapse-icon]');

    if (!toggle || !icon) return;

    const setCollapsed = (collapsed) => {
      root.toggleAttribute('data-sidebar-collapsed', collapsed);
      toggle.setAttribute('aria-expanded', String(!collapsed));
      toggle.setAttribute('aria-label', collapsed ? 'Apri sidebar' : 'Chiudi sidebar');
      icon.textContent = collapsed ? '›' : '‹';
      try {
        localStorage.setItem(storageKey, collapsed ? 'true' : 'false');
      } catch {}
    };

    let saved = root.hasAttribute('data-sidebar-collapsed');
    try {
      saved = localStorage.getItem(storageKey) === 'true';
    } catch {}

    setCollapsed(saved);
    toggle.addEventListener('click', () => setCollapsed(!root.hasAttribute('data-sidebar-collapsed')));
  })();
</script>

<style>
  @layer starlight.core {
    .page {
      flex-direction: column;
      min-height: 100vh;
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: fixed;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 100%;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      padding-inline-end: var(--sl-nav-pad-x);
      background-color: var(--sl-color-bg-nav);
    }

    :global([data-has-sidebar]) .header {
      padding-inline-end: calc(
        var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size)
      );
    }

    .sidebar-pane {
      visibility: var(--sl-sidebar-visibility, hidden);
      position: fixed;
      z-index: var(--sl-z-index-menu);
      inset-block: var(--sl-nav-height) 0;
      inset-inline-start: 0;
      width: 100%;
      background-color: var(--sl-color-black);
      overflow-y: auto;
      scrollbar-gutter: stable;
    }

    :global([aria-expanded='true']) ~ .sidebar-pane {
      --sl-sidebar-visibility: visible;
    }

    .sidebar-content {
      height: 100%;
      min-height: max-content;
      padding: 1rem var(--sl-sidebar-pad-x) 0;
      flex-direction: column;
      gap: 1rem;
    }

    .sidebar-collapse-toggle {
      display: none;
    }

    @media (min-width: 50rem) {
      .sidebar-content::after {
        content: '';
        padding-bottom: 1px;
      }
    }

    .main-frame {
      padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
      padding-inline-start: var(--sl-content-inline-start);
    }

    @media (min-width: 50rem) {
      :global([data-has-sidebar]) .header {
        padding-inline-end: var(--sl-nav-pad-x);
      }

      .sidebar-pane {
        --sl-sidebar-visibility: visible;
        width: var(--sl-sidebar-width);
        background-color: var(--sl-color-bg-sidebar);
        border-inline-end: 1px solid var(--sl-color-hairline-shade);
      }

      .sidebar-collapse-toggle {
        position: fixed;
        z-index: calc(var(--sl-z-index-menu) + 1);
        inset-block-start: calc(var(--sl-nav-height) + 0.75rem);
        inset-inline-start: calc(var(--sl-sidebar-width) - 0.9rem);
        display: grid;
        place-items: center;
        width: 1.8rem;
        height: 1.8rem;
        border: 1px solid var(--sl-color-hairline-shade);
        border-radius: 999px;
        background: var(--sl-color-bg-nav);
        color: var(--sl-color-text);
        box-shadow: 0 0.25rem 0.8rem rgb(0 0 0 / 0.18);
        cursor: pointer;
      }

      .sidebar-collapse-toggle:hover {
        color: var(--sl-color-text-accent);
        border-color: var(--sl-color-text-accent);
      }

      :global(html[data-sidebar-collapsed]) {
        --sl-content-inline-start: 0rem !important;
      }

      :global(html[data-sidebar-collapsed]) .sidebar-pane {
        display: none;
      }

      :global(html[data-sidebar-collapsed]) .sidebar-collapse-toggle {
        inset-inline-start: 0.75rem;
      }
    }
  }
</style>
