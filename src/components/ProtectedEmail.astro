---
type Props = {
  user: string;
  domain: string;
  label?: string;
};

const { user, domain, label = 'Mostra email' } = Astro.props;
---

<protected-email data-user={user} data-domain={domain}>
  <div class="protected-email not-content">
    <label class="protected-email__challenge">
      <span data-question>Complete the anti-spam check.</span>
      <input type="number" inputmode="numeric" autocomplete="off" data-answer />
    </label>
    <button type="button" class="protected-email__button" data-reveal>{label}</button>
    <p class="protected-email__result" data-result aria-live="polite"></p>
  </div>
</protected-email>

<script>
  class ProtectedEmail extends HTMLElement {
    connectedCallback() {
      const user = this.dataset.user;
      const domain = this.dataset.domain;
      const question = this.querySelector('[data-question]');
      const answer = this.querySelector('[data-answer]');
      const reveal = this.querySelector('[data-reveal]');
      const result = this.querySelector('[data-result]');

      if (!user || !domain || !question || !answer || !reveal || !result) return;

      const a = Math.floor(Math.random() * 7) + 2;
      const b = Math.floor(Math.random() * 7) + 2;
      const expected = a + b;

      question.textContent = `What is ${a} + ${b}?`;

      reveal.addEventListener('click', () => {
        if (Number(answer.value) !== expected) {
          result.textContent = 'Incorrect answer. Please try again.';
          return;
        }

        const address = `${user}@${domain}`;
        result.innerHTML = '';

        const link = document.createElement('a');
        link.href = `mailto:${address}`;
        link.textContent = address;
        result.append(link);
      });
    }
  }

  if (!customElements.get('protected-email')) {
    customElements.define('protected-email', ProtectedEmail);
  }
</script>

<style>
  .protected-email {
    display: grid;
    gap: 0.75rem;
    max-width: 28rem;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7);
  }

  .protected-email__result {
    margin: 0;
  }

  .protected-email__challenge {
    display: grid;
    gap: 0.4rem;
    font-weight: 600;
  }

  .protected-email__challenge input {
    width: 8rem;
    padding: 0.45rem 0.55rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.35rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
  }

  .protected-email__button {
    justify-self: start;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-accent);
    border-radius: 0.35rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    font-weight: 700;
    cursor: pointer;
  }

  .protected-email__button:hover {
    filter: brightness(1.05);
  }
</style>
